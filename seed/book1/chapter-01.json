  "grammar": [
    {
      "slot": "A",
      "title": "Simple Statement",
      "pattern": "저는 NOUN + -이에요/예요. = I am NOUN.",
      "meaning": "I am NOUN.",
      "explanation": "* If the last syllable of the noun ends with a consonant, add -이에요. If the last syllable of the noun ends with a vowel, add -예요.",
      "examples": [
        {
          "korean": "저는 김성찬 + -이에요/예요 → 저는 김성찬이에요.",
          "romanization": "",
          "english": "I am Seong-chan Kim."
        },
        {
          "korean": "저는 선경화 + -이에요/예요 → 저는 선경화예요.",
          "romanization": "",
          "english": "I am Kyung-hwa Sun."
        }
      ],
