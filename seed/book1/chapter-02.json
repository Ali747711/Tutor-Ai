  "grammar": [
    {
      "slot": "A",
      "title": "Polite Request",
      "pattern": "VERB + -아/어/여 주세요. = Please VERB (me).",
      "meaning": "Please VERB (me).",
      "explanation": "* If the verb stem ends with ㅏ or ㅗ, it is followed by -아 주세요. If the verb stem ends with 하, it is followed by -여 주세요. For all other verb stem endings, use -어 주세요.",
      "examples": [
        {
          "korean": "전화하다 + -아/어/여 주세요 → 전화하여 주세요. → 전화해 주세요.",
          "romanization": "",
          "english": "Please call (me)."
        },
        {
          "korean": "만나다 + -아/어/여 주세요 → 만나아 주세요. → 만나 주세요.",
          "romanization": "",
          "english": "Please meet (me)."
        },
        {
          "korean": "가르치다 + -아/어/여 주세요 → 가르치어 주세요. → 가르쳐 주세요.",
          "romanization": "",
          "english": "Please teach (me)."
        }
      ],
