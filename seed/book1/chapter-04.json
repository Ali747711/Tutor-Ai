  "grammar": [
    {
      "slot": "A",
      "title": "Subordinating Conjunction with a Noun",
      "pattern": "NOUN + -(이)라서 = because it is NOUN",
      "meaning": "because it is NOUN",
      "explanation": "If a noun ends with a vowel, attach -라서 at the end, and if it ends with a consonant, use -이라서.",
      "examples": [
        {
          "korean": "생일 + -(이)라서 → 생일이라서",
          "romanization": "",
          "english": "because it is one's birthday"
        },
        {
          "korean": "숙제 + -(이)라서 → 숙제라서",
          "romanization": "",
          "english": "because it is homework"
        }
      ],
      "exercises": [
        {
