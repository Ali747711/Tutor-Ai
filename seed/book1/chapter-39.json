  "longDialogue": [
    {
      "speaker": "보람",
      "korean": "우와! 드디어 여행 시작!",
      "romanization": "",
      "english": "Wow! The trip finally begins!"
    },
    {
      "speaker": "해윤",
      "korean": "나 비행기 처음 타. 해외여행도 처음이야.",
      "romanization": "",
      "english": "This is my first time riding an airplane. It's also my first time traveling overseas."
    },
    {
      "speaker": "보람",
      "korean": "진짜? 네가 창가에 앉아.",
      "romanization": "",
      "english": "Really? Sit by the window."
    },
    {
      "speaker": "해윤",
      "korean": "그래. 기내식도 먹고 싶다.",
      "romanization": "",
      "english": "Ok. I want to try the in-flight meal, too."
    },
    {
      "speaker": "보람",
      "korean": "해윤아. 우리 일본 가서 기내식 없어.",
      "romanization": "",
      "english": "Hae-yun, we are going to Japan, so there is no in-flight meal."
    },
    {
      "speaker": "해윤",
      "korean": "정말?",
      "romanization": "",
      "english": "Really?"
    },
    {
      "speaker": "보람",
      "korean": "어. 2시간밖에 안 걸려.",
      "romanization": "",
      "english": "Yeah. It only takes 2 hours."
    },
    {
      "speaker": "해윤",
      "korean": "아··· 기내식 먹고 싶다.",
      "romanization": "",
      "english": "Argh... I want to have an in-flight meal."
    },
    {
      "speaker": "보람",
      "korean": "해윤아. 비행기 탈 때 신발 벗고 타. 알지?",
